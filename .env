# Jira Configuration — secrets (server-side only, no VITE_ prefix)
# Real values go in .env.local (gitignored) — never commit secrets here!
JIRA_DOMAIN=your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Jira Configuration — non-secrets (visible in frontend bundle)
VITE_JIRA_DOMAIN=your-domain.atlassian.net
VITE_JIRA_PROJECT_KEY=YOUR_PROJECT_KEY
VITE_GLOBAL_DELIVERY=Global Delivery

#Team pixels
# Jira group name whose members = Pixels team (leave empty to scan issue assignees instead)
VITE_JIRA_PIXELS_GROUP=Pixels Team
VITE_ID_ALICJA=
VITE_ID_RAKU=
VITE_ID_TOMEK=
VITE_ID_KRZYSIEK=
VITE_ID_OLIWER=
VITE_ID_BARTOSZ=

# Team Configuration
VITE_TEAM_FIELD_NAME=Team

# User Roles Configuration
VITE_ROLE_TOMASZ_RUSINSKI=Software Engineer
VITE_ROLE_BARTOSZ_BOSSY=Associate Manager, Engineering
VITE_ROLE_OLIWER_PAWELSKI=Associate Software Engineer
VITE_ROLE_KRZYSZTOF_RAK=Associate Software Engineer
VITE_ROLE_KRZYSZTOF_ADAMEK=Senior Software Engineer
VITE_ROLE_ALICJA_WOLNIK=Senior Software Engineer

# Server Configuration
VITE_API_BASE_URL=http://localhost:3001

# AWS DynamoDB Local Configuration (Docker)
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:8000

# Frontend AWS Configuration (with VITE_ prefix)
VITE_AWS_ACCESS_KEY_ID=dummy
VITE_AWS_SECRET_ACCESS_KEY=dummy

# Frontend DynamoDB Configuration (with VITE_ prefix)
VITE_AWS_REGION=us-east-1
VITE_DYNAMODB_ENDPOINT=http://localhost:8000
VITE_DYNAMODB_USERS_TABLE=Users
VITE_DYNAMODB_USER_SETTINGS_TABLE=TableSettings
